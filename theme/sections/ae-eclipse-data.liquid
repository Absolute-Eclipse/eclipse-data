    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Tell us where you'll be — we compute exactly what you'll see, when, and whether your spot can catch it. Validated against NASA, computed live in your browser." },
    { "type": "select", "id": "default_event", "label": "Default eclipse", "default": "2026", "options": [ { "value": "2026", "label": "12 Aug 2026" }, { "value": "2027", "label": "2 Aug 2027" } ] },
    { "type": "range", "id": "padding_block", "label": "Vertical padding", "min": 16, "max": 160, "step": 4, "unit": "px", "default": 64 }
  ],
  "presets": [ { "name": "AE Eclipse Data" } ]
}
