    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#000f9f" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Eclipse data · 12 Aug 2026 & 2 Aug 2027" },
